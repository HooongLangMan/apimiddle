DOMAIN=panel.token688.cn
API_DOMAIN=api.token688.cn
LETSENCRYPT_EMAIL=honglangman_32175@163.com

TZ=Asia/Shanghai
NEW_API_PORT=3000

# Generate long random values before production use.
SESSION_SECRET=replace-with-a-long-random-session-secret
CRYPTO_SECRET=replace-with-a-long-random-crypto-secret

# PostgreSQL
POSTGRES_DB=new_api
POSTGRES_USER=newapi
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_PORT=5432
SQL_DSN=postgresql://newapi:replace-with-a-strong-postgres-password@postgres:5432/new_api

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_PORT=6379
REDIS_CONN_STRING=redis://:replace-with-a-strong-redis-password@redis:6379/0

# Request guards
STREAMING_TIMEOUT=300
MAX_REQUEST_BODY_MB=32
ERROR_LOG_ENABLED=true
GENERATE_DEFAULT_TOKEN=false

# Cloudflare Tunnel
# Leave empty if you are not using Tunnel yet.
CLOUDFLARE_TUNNEL_TOKEN=

# Optional backups
BACKUP_RETENTION_DAYS=7
