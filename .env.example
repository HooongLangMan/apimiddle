DOMAIN=token688.cn
LETSENCRYPT_EMAIL=honglangman_32175@163.com

# Bind Caddy to a high port for local validation first. Change to 80 in production.
CADDY_HTTP_PORT=8080

# Internal app settings
TZ=Asia/Shanghai
NEW_API_PORT=3000

# Set a long random string before public deployment.
SESSION_SECRET=replace-with-a-long-random-session-secret

# Optional now, required when you add Redis or multi-node later.
CRYPTO_SECRET=replace-with-a-long-random-crypto-secret

# Leave empty to use SQLite at /data/sqlite.db.
SQL_DSN=
REDIS_CONN_STRING=

# Resource guards
STREAMING_TIMEOUT=300
MAX_REQUEST_BODY_MB=32
ERROR_LOG_ENABLED=true

# Optional bootstrap convenience. Review before enabling.
GENERATE_DEFAULT_TOKEN=false
